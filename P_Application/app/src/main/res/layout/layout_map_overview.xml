<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- AI 공학관 (선택 불가) -->
    <TextView
        android:id="@+id/viewBuilding"
        android:layout_width="100dp"
        android:layout_height="0dp"
        android:text="AI\n공학관"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="#666666"
        app:layout_constraintHeight_percent="0.7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.3"/>

    <!-- 1구역 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnZone1Main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="1구역"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintEnd_toStartOf="@id/viewBuilding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/viewBuilding"
        app:layout_constraintBottom_toTopOf="@id/guideLineHorizontal"/>

    <!-- 가상의 가로선 (1구역과 2구역 사이) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLineHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5"/>

    <!-- 2구역 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnZone2Main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="2구역"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1976D2"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toStartOf="@id/viewBuilding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnZone1Main"
        app:layout_constraintBottom_toBottomOf="@id/viewBuilding"/>

    <!-- 3구역 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnZone3Main"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="3구역"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#388E3C"
        android:rotation="10"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnZone2Main"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/viewBuilding"/>

</androidx.constraintlayout.widget.ConstraintLayout>