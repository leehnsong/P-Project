<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="주차장 맵 빌더"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBuilderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="P1 다음 슬롯: 1 / 등록: 0개"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgBuilderZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <RadioButton
                    android:id="@+id/rbBuilderP1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_builder_zone_selector"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="1구역"
                    android:textColor="@color/builder_zone_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbBuilderP2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_builder_zone_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="2구역"
                    android:textColor="@color/builder_zone_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbBuilderP3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_builder_zone_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="3구역"
                    android:textColor="@color/builder_zone_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RadioGroup>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <com.example.pproject.MapBuilderView
            android:id="@+id/mapBuilderView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="각도"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekAngle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="@color/brand_primary"
                    android:thumbTint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvAngleValue"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0도"
                    android:textColor="#666666" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="너비"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekWidth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progress="40"
                    android:progressTint="@color/brand_primary"
                    android:thumbTint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvWidthValue"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="40"
                    android:textColor="#666666" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="높이"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progress="70"
                    android:progressTint="@color/brand_primary"
                    android:thumbTint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvHeightValue"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="70"
                    android:textColor="#666666" />
            </LinearLayout>

            <CheckBox
                android:id="@+id/cbDisabledSlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/brand_primary"
                android:text="장애인 주차구역으로 표시"
                android:textColor="@color/black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnUndoSlot"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:backgroundTint="#888888"
                    android:text="되돌리기"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDeleteSlot"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#888888"
                    android:text="삭제"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnClearZone"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#888888"
                    android:text="초기화"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnExportJson"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/brand_primary"
                    android:text="JSON 보기"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnCopyJson"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/brand_primary"
                    android:text="복사"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_builder_output"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvBuilderOutput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="JSON 보기 또는 복사를 누르면 partition별 슬롯 데이터가 출력됩니다."
                    android:textColor="#444444"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
