<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="주차장 맵 빌더"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rgBuilderZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbBuilderP1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="P1" />

        <RadioButton
            android:id="@+id/rbBuilderP2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P2" />

        <RadioButton
            android:id="@+id/rbBuilderP3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P3" />
    </RadioGroup>

    <TextView
        android:id="@+id/tvBuilderStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="P1 다음 슬롯: 1 / 등록: 0개"
        android:textColor="@color/brand_primary"
        android:textStyle="bold" />

    <com.example.pproject.MapBuilderView
        android:id="@+id/mapBuilderView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="각도" />

        <SeekBar
            android:id="@+id/seekAngle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvAngleValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0도" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="너비" />

        <SeekBar
            android:id="@+id/seekWidth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progress="40" />

        <TextView
            android:id="@+id/tvWidthValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="40" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="높이" />

        <SeekBar
            android:id="@+id/seekHeight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progress="70" />

        <TextView
            android:id="@+id/tvHeightValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="70" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbDisabledSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="선택한 슬롯 또는 다음 슬롯을 장애인 구역으로 표시" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnUndoSlot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="되돌리기" />

        <Button
            android:id="@+id/btnDeleteSlot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="삭제" />

        <Button
            android:id="@+id/btnClearZone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="초기화" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnExportJson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="JSON 보기" />

        <Button
            android:id="@+id/btnCopyJson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="복사" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="6dp"
        android:background="@color/white"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvBuilderOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JSON 보기 또는 복사를 누르면 partition별 슬롯 데이터가 출력됩니다."
            android:textColor="#444444"
            android:textIsSelectable="true"
            android:textSize="12sp" />
    </ScrollView>
</LinearLayout>
