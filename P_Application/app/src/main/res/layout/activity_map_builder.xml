<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="주차장 맵 빌더"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Python 슬롯 라벨링 도구처럼 지도 위를 드래그해서 슬롯 사각형을 만들고 JSON으로 내보냅니다."
        android:textColor="#666666"
        android:textSize="13sp" />

    <RadioGroup
        android:id="@+id/rgBuilderZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbBuilderP1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="P1" />

        <RadioButton
            android:id="@+id/rbBuilderP2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P2" />

        <RadioButton
            android:id="@+id/rbBuilderP3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="P3" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/cbDisabledSlot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="다음 슬롯을 장애인 구역으로 표시" />

        <Button
            android:id="@+id/btnUndoSlot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="되돌리기" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvBuilderStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="P1 다음 슬롯: 1 / 등록: 0개"
        android:textColor="@color/brand_primary"
        android:textStyle="bold" />

    <com.example.pproject.MapBuilderView
        android:id="@+id/mapBuilderView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnClearZone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="현재 구역 초기화" />

        <Button
            android:id="@+id/btnExportJson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="JSON 보기" />

        <Button
            android:id="@+id/btnCopyJson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="복사" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="8dp"
        android:background="@color/white"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvBuilderOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JSON 보기 또는 복사를 누르면 mapping_parking_slot.json 형식으로 출력됩니다."
            android:textColor="#444444"
            android:textIsSelectable="true"
            android:textSize="12sp" />
    </ScrollView>
</LinearLayout>
